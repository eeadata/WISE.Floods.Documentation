# Local copy of the EA model — not versioned, each machine/environment provides its own
data/*.qea
data/*.qeax

# HTML generated by Sphinx — GitHub Actions rebuilds it on every push
# (no need to version it; if your team decides to version it too, comment out this line)
_build/

# Local environment files / credentials
.env

# Python caches and temp files
__pycache__/
*.pyc

# Sphinx error logs
sphinx-err-*.log

# Operating system files
.DS_Store
Thumbs.db

# md files generating scripts and some utils
generate_md_*.py
tools/

.vscode/
